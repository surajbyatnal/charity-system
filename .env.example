# Blockchain Charity App - Environment Configuration
# Copy to .env and edit secrets

# MySQL Database (required for backend)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password  # CHANGE THIS to your MySQL root password
DB_NAME=charity_app

# Backend Server
PORT=5000

# Ganache (auto-configured in package.json)
GANACHE_HOST=127.0.0.1
GANACHE_PORT=7545
GANACHE_NETWORK_ID=5777

# Truffle (auto-configured)
CONTRACT_ADDRESS=  # Will be filled after migration
